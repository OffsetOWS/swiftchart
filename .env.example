# SwiftChart VPS environment template.
# Copy this file to /opt/swiftchart/.env on the VPS and fill in secrets there.

# Frontend
# Use empty string when frontend and API are served from the same VPS/domain.
VITE_API_BASE=
VITE_EXECUTION_API_BASE=
VITE_TELEGRAM_BOT_URL=https://t.me/SwiftChartBot
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend
APP_NAME=SwiftChart
ENVIRONMENT=production
DATABASE_URL=sqlite:////opt/swiftchart/swiftchart.db
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
FRONTEND_ORIGINS=http://156.67.30.173,https://YOUR_DOMAIN
LIVE_TRADING_ENABLED=false
DEFAULT_EXCHANGE=hyperliquid
DEFAULT_TIMEFRAME=4h
DEFAULT_ACCOUNT_SIZE=10000
DEFAULT_RISK_PER_TRADE=1
DEFAULT_MIN_RR=2
DEFAULT_MAX_OPEN_TRADES=3
TRADE_HISTORY_EXPIRY_BARS=12

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_ALERT_CHAT_IDS=
ALERTS_ENABLED=true
ALERT_EXCHANGE=hyperliquid
ALERT_TIMEFRAME=4h
ALERT_SCAN_INTERVAL_SECONDS=1800
ALERTS_RUN_SECRET=
BOT_STATE_PATH=/opt/swiftchart/.swiftchart_bot_state.json
HYPERLIQUID_API_KEY=

# Execution Bot
# Default is safe paper trading. Live mode requires both values below.
EXECUTION_DATABASE_URL=sqlite:////opt/swiftchart/execution_bot.db
EXECUTION_WEBHOOK_SECRET=
EXECUTION_AUTOTRADE_ENABLED=false
EXECUTION_SIGNAL_WEBHOOK_URL=http://127.0.0.1:8100/webhook/signal
EXECUTION_MODE=paper
EXECUTION_LIVE_CONFIRM=false
LIVE_TRADING=false
AUTO_EXECUTE=false
EXECUTION_EXCHANGE=mock
EXECUTION_TELEGRAM_BOT_TOKEN=
EXECUTION_TELEGRAM_ADMIN_ID=
EXECUTION_TELEGRAM_POLLING_ENABLED=true
EXECUTION_QUOTE_ASSET=USDT
STARTING_BALANCE=100
TARGET_BALANCE=1000
BASE_RISK_PERCENT=2
MAX_RISK_PERCENT=5
MAX_DAILY_LOSS_PERCENT=8
MAX_WEEKLY_LOSS_PERCENT=15
MAX_OPEN_TRADES=2
MAX_LEVERAGE=5
MAX_CONSECUTIVE_LOSSES=3
MIN_CONFIDENCE_TO_TRADE=75
MAX_EXPOSURE_PER_COIN_PERCENT=45
MIN_ORDER_NOTIONAL=10
COOLDOWN_AFTER_LOSS_MINUTES=30
SIGNAL_TTL_SECONDS=900
DUPLICATE_WINDOW_SECONDS=3600
MIN_ATR_PERCENT=0.08
MAX_ATR_PERCENT=8
MAX_SPREAD_PERCENT=0.25
MIN_VOLUME_RATIO=0.55
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_API_WALLET_ADDRESS=
HYPERLIQUID_API_KEY=
HYPERLIQUID_API_SECRET=
